generator client {
  provider        = "prisma-client-js"
  output          = "client"
  previewFeatures = ["postgresqlExtensions", "views"]
  binaryTargets   = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BOM {
  id                                         String             @id @default(uuid()) @db.Uuid
  name                                       String             @unique @db.VarChar(140)
  item                                       String             @db.VarChar(140)
  item_name                                  String?            @db.VarChar(140)
  description                                String?
  uom                                        String?            @db.VarChar(140)
  stock_uom                                  String?            @db.VarChar(140)
  quantity                                   Decimal            @default(0) @db.Decimal(18, 6)
  company                                    String             @db.VarChar(140)
  currency                                   String             @db.VarChar(140)
  conversion_rate                            Decimal            @default(1) @db.Decimal(18, 9)
  price_list_currency                        String?            @db.VarChar(140)
  plc_conversion_rate                        Decimal            @default(1) @db.Decimal(18, 9)
  rm_cost_as_per                             String?            @db.VarChar(140)
  buying_price_list                          String?            @db.VarChar(140)
  with_operations                            Boolean            @default(false)
  track_semi_finished_goods                  Boolean            @default(false)
  transfer_material_against                  String?            @db.VarChar(140)
  routing                                    String?            @db.VarChar(140)
  operating_cost                             Decimal            @default(0) @db.Decimal(18, 2)
  base_operating_cost                        Decimal            @default(0) @db.Decimal(18, 2)
  raw_material_cost                          Decimal            @default(0) @db.Decimal(18, 2)
  base_raw_material_cost                     Decimal            @default(0) @db.Decimal(18, 2)
  secondary_items_cost                       Decimal            @default(0) @db.Decimal(18, 2)
  base_secondary_items_cost                  Decimal            @default(0) @db.Decimal(18, 2)
  total_cost                                 Decimal            @default(0) @db.Decimal(18, 2)
  base_total_cost                            Decimal            @default(0) @db.Decimal(18, 2)
  cost_allocation_per                        Decimal            @default(100) @db.Decimal(18, 6)
  cost_allocation                            Decimal            @default(0) @db.Decimal(18, 2)
  process_loss_percentage                    Decimal            @default(0) @db.Decimal(18, 6)
  process_loss_qty                           Decimal            @default(0) @db.Decimal(18, 6)
  is_active                                  Boolean            @default(false)
  is_default                                 Boolean            @default(false)
  is_phantom_bom                             Boolean            @default(false)
  allow_alternative_item                     Boolean            @default(false)
  set_rate_of_sub_assembly_item_based_on_bom Boolean            @default(false)
  fg_based_operating_cost                    Boolean            @default(false)
  operating_cost_per_bom_quantity            Decimal            @default(0) @db.Decimal(18, 2)
  inspection_required                        Boolean            @default(false)
  quality_inspection_template                String?            @db.VarChar(140)
  default_source_warehouse                   String?            @db.VarChar(140)
  default_target_warehouse                   String?            @db.VarChar(140)
  backflush_based_on                         String?            @db.VarChar(140)
  project                                    String?            @db.VarChar(140)
  show_in_website                            Boolean            @default(false)
  route                                      String?
  website_image                              String?            @db.VarChar(140)
  thumbnail                                  String?            @db.VarChar(140)
  web_long_description                       String?
  show_items                                 Boolean            @default(false)
  show_operations                            Boolean            @default(false)
  has_variants                               Boolean            @default(false)
  bom_creator                                String?            @db.VarChar(140)
  bom_creator_item                           String?            @db.VarChar(140)
  amended_from                               String?            @db.VarChar(140)
  docstatus                                  Int                @default(0)
  explodedItems                              BOMExplosionItem[]
  items                                      BOMItem[]
  operations                                 BOMOperation[]
  secondaryItems                             BOMSecondaryItem[]
}

model BOMItem {
  id                            String  @id @default(uuid()) @db.Uuid
  name                          String? @unique @db.VarChar(140)
  idx                           Int     @default(0)
  item_code                     String  @db.VarChar(140)
  item_name                     String? @db.VarChar(140)
  bom_no                        String? @db.VarChar(140)
  operation                     String? @db.VarChar(140)
  operation_row_id              Int?    @default(0)
  do_not_explode                Boolean @default(false)
  source_warehouse              String? @db.VarChar(140)
  allow_alternative_item        Boolean @default(false)
  is_stock_item                 Boolean @default(false)
  description                   String?
  image                         String? @db.VarChar(140)
  qty                           Decimal @default(0) @db.Decimal(18, 6)
  uom                           String? @db.VarChar(140)
  stock_qty                     Decimal @default(0) @db.Decimal(18, 6)
  stock_uom                     String? @db.VarChar(140)
  conversion_factor             Decimal @default(1) @db.Decimal(18, 9)
  rate                          Decimal @default(0) @db.Decimal(18, 9)
  base_rate                     Decimal @default(0) @db.Decimal(18, 9)
  amount                        Decimal @default(0) @db.Decimal(18, 2)
  base_amount                   Decimal @default(0) @db.Decimal(18, 2)
  qty_consumed_per_unit         Decimal @default(0) @db.Decimal(18, 9)
  has_variants                  Boolean @default(false)
  include_item_in_manufacturing Boolean @default(false)
  original_item                 String? @db.VarChar(140)
  sourced_by_supplier           Boolean @default(false)
  is_sub_assembly_item          Boolean @default(false)
  is_phantom_item               Boolean @default(false)
  bomId                         String  @db.Uuid
  bom                           BOM     @relation(fields: [bomId], references: [id], onDelete: Cascade)
}

model BOMOperation {
  id                           String  @id @default(uuid()) @db.Uuid
  name                         String? @unique @db.VarChar(140)
  idx                          Int     @default(0)
  operation                    String  @db.VarChar(140)
  description                  String?
  workstation                  String? @db.VarChar(140)
  workstation_type             String? @db.VarChar(140)
  time_in_mins                 Decimal @default(0) @db.Decimal(18, 6)
  hour_rate                    Decimal @default(0) @db.Decimal(18, 9)
  base_hour_rate               Decimal @default(0) @db.Decimal(18, 9)
  operating_cost               Decimal @default(0) @db.Decimal(18, 2)
  base_operating_cost          Decimal @default(0) @db.Decimal(18, 2)
  batch_size                   Int     @default(1)
  cost_per_unit                Decimal @default(0) @db.Decimal(18, 9)
  base_cost_per_unit           Decimal @default(0) @db.Decimal(18, 9)
  sequence_id                  Int?    @default(0)
  fixed_time                   Boolean @default(false)
  set_cost_based_on_bom_qty    Boolean @default(false)
  finished_good                String? @db.VarChar(140)
  finished_good_qty            Decimal @default(0) @db.Decimal(18, 6)
  bom_no                       String? @db.VarChar(140)
  is_subcontracted             Boolean @default(false)
  is_final_finished_good       Boolean @default(false)
  skip_material_transfer       Boolean @default(false)
  backflush_from_wip_warehouse Boolean @default(false)
  source_warehouse             String? @db.VarChar(140)
  wip_warehouse                String? @db.VarChar(140)
  fg_warehouse                 String? @db.VarChar(140)
  quality_inspection_required  Boolean @default(false)
  bomId                        String  @db.Uuid
  bom                          BOM     @relation(fields: [bomId], references: [id], onDelete: Cascade)
}

model BOMExplosionItem {
  id                            String  @id @default(uuid()) @db.Uuid
  name                          String? @unique @db.VarChar(140)
  item_code                     String  @db.VarChar(140)
  item_name                     String? @db.VarChar(140)
  source_warehouse              String? @db.VarChar(140)
  operation                     String? @db.VarChar(140)
  description                   String?
  image                         String? @db.VarChar(140)
  stock_qty                     Decimal @default(0) @db.Decimal(18, 6)
  stock_uom                     String? @db.VarChar(140)
  rate                          Decimal @default(0) @db.Decimal(18, 9)
  amount                        Decimal @default(0) @db.Decimal(18, 2)
  qty_consumed_per_unit         Decimal @default(0) @db.Decimal(18, 9)
  include_item_in_manufacturing Boolean @default(false)
  sourced_by_supplier           Boolean @default(false)
  is_sub_assembly_item          Boolean @default(false)
  bomId                         String  @db.Uuid
  bom                           BOM     @relation(fields: [bomId], references: [id], onDelete: Cascade)
}

model BOMSecondaryItem {
  id                  String  @id @default(uuid()) @db.Uuid
  name                String? @unique @db.VarChar(140)
  idx                 Int     @default(0)
  type                String? @db.VarChar(140)
  item_code           String  @db.VarChar(140)
  item_name           String? @db.VarChar(140)
  uom                 String? @db.VarChar(140)
  stock_uom           String? @db.VarChar(140)
  qty                 Decimal @default(0) @db.Decimal(18, 6)
  stock_qty           Decimal @default(0) @db.Decimal(18, 6)
  conversion_factor   Decimal @default(1) @db.Decimal(18, 9)
  cost_allocation_per Decimal @default(0) @db.Decimal(18, 6)
  process_loss_per    Decimal @default(0) @db.Decimal(18, 6)
  process_loss_qty    Decimal @default(0) @db.Decimal(18, 6)
  cost                Decimal @default(0) @db.Decimal(18, 2)
  base_cost           Decimal @default(0) @db.Decimal(18, 2)
  rate                Decimal @default(0) @db.Decimal(18, 9)
  description         String?
  image               String? @db.VarChar(140)
  is_legacy           Boolean @default(false)
  bomId               String  @db.Uuid
  bom                 BOM     @relation(fields: [bomId], references: [id], onDelete: Cascade)
}

model Account {
  name             String    @id @db.VarChar(140)
  creation         DateTime? @default(now()) @db.Timestamptz(3)
  modified         DateTime? @updatedAt @db.Timestamptz(3)
  modified_by      String?   @db.VarChar(255)
  owner            String?   @db.VarChar(255)
  docstatus        Int       @default(0)
  idx              Int       @default(0)
  account_name     String    @db.VarChar(255)
  account_number   String?   @db.VarChar(255)
  is_group         Boolean   @default(false)
  company          String    @db.VarChar(140)
  root_type        String?   @db.VarChar(100)
  report_type      String?   @db.VarChar(100)
  account_currency String?   @db.VarChar(140)
  parent_account   String    @db.VarChar(140)
  account_type     String?   @db.VarChar(100)
  tax_rate         Float
  freeze_account   String?   @db.VarChar(100)
  balance_must_be  String?   @db.VarChar(100)
  lft              Int
  rgt              Int
  old_parent       String?   @db.VarChar(255)
  include_in_gross Boolean   @default(false)
  disabled         Boolean   @default(false)
  account_category String?   @db.VarChar(140)

  @@index([company])
  @@index([account_currency])
  @@index([parent_account])
  @@index([account_category])
  @@map("account")
}

model AccountCategory {
  name                  String    @id @db.VarChar(140)
  creation              DateTime? @default(now()) @db.Timestamptz(3)
  modified              DateTime? @updatedAt @db.Timestamptz(3)
  modified_by           String?   @db.VarChar(255)
  owner                 String?   @db.VarChar(255)
  docstatus             Int?      @default(0)
  idx                   Int?      @default(0)
  account_category_name String    @unique @db.VarChar(255)
  description           String?
  root_type             String?   @db.VarChar(100)

  @@map("account_category")
}

model AccountClosingBalance {
  name                             String    @id @db.VarChar(140)
  creation                         DateTime? @default(now()) @db.Timestamptz(3)
  modified                         DateTime? @updatedAt @db.Timestamptz(3)
  modified_by                      String?   @db.VarChar(255)
  owner                            String?   @db.VarChar(255)
  docstatus                        Int?      @default(0)
  idx                              Int?      @default(0)
  closing_date                     DateTime? @db.Timestamptz(3)
  account                          String?   @db.VarChar(140)
  cost_center                      String?   @db.VarChar(140)
  debit                            Decimal?  @db.Decimal(18, 2)
  credit                           Decimal?  @db.Decimal(18, 2)
  account_currency                 String?   @db.VarChar(140)
  debit_in_account_currency        Decimal?  @db.Decimal(18, 2)
  credit_in_account_currency       Decimal?  @db.Decimal(18, 2)
  project                          String?   @db.VarChar(140)
  company                          String?   @db.VarChar(140)
  finance_book                     String?   @db.VarChar(140)
  period_closing_voucher           String?   @db.VarChar(140)
  is_period_closing_voucher_entry  Boolean?  @default(false)
  debit_in_reporting_currency      Decimal?  @db.Decimal(18, 2)
  credit_in_reporting_currency     Decimal?  @db.Decimal(18, 2)
  reporting_currency_exchange_rate Float?

  @@index([account])
  @@index([cost_center])
  @@index([account_currency])
  @@index([project])
  @@index([company])
  @@index([finance_book])
  @@index([period_closing_voucher])
  @@map("account_closing_balance")
}

model AccountingDimension {
  name          String    @id @db.VarChar(140)
  creation      DateTime? @default(now()) @db.Timestamptz(3)
  modified      DateTime? @updatedAt @db.Timestamptz(3)
  modified_by   String?   @db.VarChar(255)
  owner         String?   @db.VarChar(255)
  docstatus     Int?      @default(0)
  idx           Int?      @default(0)
  label         String?   @unique @db.VarChar(255)
  fieldname     String?   @db.VarChar(255)
  document_type String    @db.VarChar(140)
  disabled      Boolean?  @default(false)

  @@index([document_type])
  @@map("accounting_dimension")
}

model AccountingDimensionDetail {
  name                                          String    @id @db.VarChar(140)
  creation                                      DateTime? @default(now()) @db.Timestamptz(3)
  modified                                      DateTime? @updatedAt @db.Timestamptz(3)
  modified_by                                   String?   @db.VarChar(255)
  owner                                         String?   @db.VarChar(255)
  docstatus                                     Int?      @default(0)
  idx                                           Int?      @default(0)
  parent                                        String?   @db.VarChar(140)
  parentfield                                   String?   @db.VarChar(255)
  parenttype                                    String?   @db.VarChar(255)
  company                                       String?   @db.VarChar(140)
  reference_document                            String?   @db.VarChar(140)
  default_dimension                             String?   @db.VarChar(140)
  mandatory_for_bs                              Boolean?  @default(false)
  mandatory_for_pl                              Boolean?  @default(false)
  automatically_post_balancing_accounting_entry Boolean?  @default(false)
  offsetting_account                            String?   @db.VarChar(140)

  @@index([company])
  @@index([reference_document])
  @@index([offsetting_account])
  @@map("accounting_dimension_detail")
}

model AccountingDimensionFilter {
  name                        String    @id @db.VarChar(140)
  creation                    DateTime? @default(now()) @db.Timestamptz(3)
  modified                    DateTime? @updatedAt @db.Timestamptz(3)
  modified_by                 String?   @db.VarChar(255)
  owner                       String?   @db.VarChar(255)
  docstatus                   Int?      @default(0)
  idx                         Int?      @default(0)
  accounting_dimension        String    @db.VarChar(100)
  allow_or_restrict           String    @db.VarChar(100)
  disabled                    Boolean?  @default(false)
  company                     String    @db.VarChar(140)
  dimension_filter_help       String?
  apply_restriction_on_values Boolean?  @default(true)
  fieldname                   String?   @db.VarChar(255)

  @@index([company])
  @@map("accounting_dimension_filter")
}

model AccountingPeriod {
  name          String    @id @db.VarChar(140)
  creation      DateTime? @default(now()) @db.Timestamptz(3)
  modified      DateTime? @updatedAt @db.Timestamptz(3)
  modified_by   String?   @db.VarChar(255)
  owner         String?   @db.VarChar(255)
  docstatus     Int?      @default(0)
  idx           Int?      @default(0)
  period_name   String    @unique @db.VarChar(255)
  start_date    DateTime  @db.Timestamptz(3)
  end_date      DateTime  @db.Timestamptz(3)
  company       String    @db.VarChar(140)
  disabled      Boolean?  @default(false)
  exempted_role String?   @db.VarChar(140)

  @@index([company])
  @@index([exempted_role])
  @@map("accounting_period")
}

model AccountsSettings {
  name                                                       String    @id @db.VarChar(140)
  creation                                                   DateTime? @default(now()) @db.Timestamptz(3)
  modified                                                   DateTime? @updatedAt @db.Timestamptz(3)
  modified_by                                                String?   @db.VarChar(255)
  owner                                                      String?   @db.VarChar(255)
  docstatus                                                  Int?      @default(0)
  idx                                                        Int?      @default(0)
  determine_address_tax_category_from                        String?   @default("Billing Address") @db.VarChar(100)
  credit_controller                                          String?   @db.VarChar(140)
  check_supplier_invoice_uniqueness                          Boolean?  @default(false)
  make_payment_via_journal_entry                             Boolean?  @default(false)
  unlink_payment_on_cancellation_of_invoice                  Boolean?  @default(true)
  unlink_advance_payment_on_cancelation_of_order             Boolean?  @default(true)
  book_asset_depreciation_entry_automatically                Boolean?  @default(true)
  add_taxes_from_item_tax_template                           Boolean?  @default(true)
  show_inclusive_tax_in_print                                Boolean?  @default(false)
  show_payment_schedule_in_print                             Boolean?  @default(false)
  allow_stale                                                Boolean?  @default(true)
  stale_days                                                 Int?      @default(1)
  automatically_fetch_payment_terms                          Boolean?  @default(false)
  over_billing_allowance                                     Decimal?  @db.Decimal(18, 2)
  automatically_process_deferred_accounting_entry            Boolean?  @default(true)
  book_deferred_entries_via_journal_entry                    Boolean?  @default(false)
  submit_journal_entries                                     Boolean?  @default(false)
  book_deferred_entries_based_on                             String?   @default("Days") @db.VarChar(100)
  delete_linked_ledger_entries                               Boolean?  @default(false)
  role_allowed_to_over_bill                                  String?   @db.VarChar(140)
  enable_common_party_accounting                             Boolean?  @default(false)
  allow_multi_currency_invoices_against_single_party_account Boolean?  @default(false)
  show_balance_in_coa                                        Boolean?  @default(true)
  book_tax_discount_loss                                     Boolean?  @default(false)
  merge_similar_account_heads                                Boolean?  @default(false)
  auto_reconcile_payments                                    Boolean?  @default(false)
  show_taxes_as_table_in_print                               Boolean?  @default(false)
  enable_party_matching                                      Boolean?  @default(false)
  enable_fuzzy_matching                                      Boolean?  @default(false)
  ignore_account_closing_balance                             Boolean?  @default(false)
  round_row_wise_tax                                         Boolean?  @default(false)
  general_ledger_remarks_length                              Int?      @default(0)
  receivable_payable_remarks_length                          Int?      @default(0)
  enable_immutable_ledger                                    Boolean?  @default(false)
  calculate_depr_using_total_days                            Boolean?  @default(false)
  create_pr_in_draft_status                                  Boolean?  @default(true)
  auto_reconciliation_job_trigger                            Int?      @default(15)
  reconciliation_queue_size                                  Int?      @default(5)
  ignore_is_opening_check_for_reporting                      Boolean?  @default(false)
  exchange_gain_loss_posting_date                            String?   @default("Payment") @db.VarChar(100)
  receivable_payable_fetch_method                            String?   @default("Buffered Cursor") @db.VarChar(100)
  maintain_same_internal_transaction_rate                    Boolean?  @default(false)
  maintain_same_rate_action                                  String?   @default("Stop") @db.VarChar(100)
  role_to_override_stop_action                               String?   @db.VarChar(140)
  confirm_before_resetting_posting_date                      Boolean?  @default(true)
  allow_pegged_currencies_exchange_rates                     Boolean?  @default(false)
  add_taxes_from_taxes_and_charges_template                  Boolean?  @default(false)
  drop_ar_procedures                                         String?   @db.VarChar(50)
  fetch_valuation_rate_for_internal_transaction              Boolean?  @default(false)
  use_legacy_budget_controller                               Boolean?  @default(false)
  use_legacy_controller_for_pcv                              Boolean?  @default(true)
  role_to_notify_on_depreciation_failure                     String?   @db.VarChar(140)
  default_ageing_range                                       String?   @default("30, 60, 90, 120") @db.VarChar(255)
  enable_discounts_and_margin                                Boolean?  @default(false)
  enable_loyalty_point_program                               Boolean?  @default(false)
  enable_accounting_dimensions                               Boolean?  @default(false)
  enable_subscription                                        Boolean?  @default(true)
  fetch_payment_schedule_in_payment_request                  Boolean?  @default(true)

  @@index([credit_controller])
  @@index([role_allowed_to_over_bill])
  @@index([role_to_override_stop_action])
  @@index([role_to_notify_on_depreciation_failure])
  @@map("accounts_settings")
}

model ActivityCost {
  name          String    @id @db.VarChar(140)
  creation      DateTime? @default(now()) @db.Timestamptz(3)
  modified      DateTime? @updatedAt @db.Timestamptz(3)
  modified_by   String?   @db.VarChar(255)
  owner         String?   @db.VarChar(255)
  docstatus     Int?      @default(0)
  idx           Int?      @default(0)
  activity_type String    @db.VarChar(140)
  employee      String?   @db.VarChar(140)
  employee_name String?   @db.VarChar(255)
  department    String?   @db.VarChar(140)
  billing_rate  Decimal?  @default(0) @db.Decimal(18, 2)
  costing_rate  Decimal?  @default(0) @db.Decimal(18, 2)
  title         String?   @db.VarChar(255)

  @@index([activity_type])
  @@index([employee])
  @@index([department])
  @@map("activity_cost")
}

model ActivityType {
  name          String    @id @db.VarChar(140)
  creation      DateTime? @default(now()) @db.Timestamptz(3)
  modified      DateTime? @updatedAt @db.Timestamptz(3)
  modified_by   String?   @db.VarChar(255)
  owner         String?   @db.VarChar(255)
  docstatus     Int?      @default(0)
  idx           Int?      @default(0)
  activity_type String    @unique @db.VarChar(255)
  costing_rate  Decimal?  @db.Decimal(18, 2)
  billing_rate  Decimal?  @db.Decimal(18, 2)
  disabled      Boolean?  @default(false)

  @@map("activity_type")
}

model AdvancePaymentLedgerEntry {
  name                 String    @id @db.VarChar(140)
  creation             DateTime? @default(now()) @db.Timestamptz(3)
  modified             DateTime? @updatedAt @db.Timestamptz(3)
  modified_by          String?   @db.VarChar(255)
  owner                String?   @db.VarChar(255)
  docstatus            Int?      @default(0)
  idx                  Int?      @default(0)
  voucher_type         String?   @db.VarChar(140)
  voucher_no           String?   @db.VarChar(140)
  against_voucher_type String?   @db.VarChar(140)
  against_voucher_no   String?   @db.VarChar(140)
  amount               Decimal?  @db.Decimal(18, 2)
  currency             String?   @db.VarChar(140)
  event                String?   @db.VarChar(255)
  company              String?   @db.VarChar(140)
  delinked             Boolean?  @default(false)
  base_amount          Decimal?  @db.Decimal(18, 2)
  exchange_rate        Float?

  @@index([voucher_type])
  @@index([against_voucher_type])
  @@index([currency])
  @@index([company])
  @@map("advance_payment_ledger_entry")
}

model AdvanceTaxesAndCharges {
  name                       String    @id @db.VarChar(140)
  creation                   DateTime? @default(now()) @db.Timestamptz(3)
  modified                   DateTime? @updatedAt @db.Timestamptz(3)
  modified_by                String?   @db.VarChar(255)
  owner                      String?   @db.VarChar(255)
  docstatus                  Int?      @default(0)
  idx                        Int?      @default(0)
  parent                     String?   @db.VarChar(140)
  parentfield                String?   @db.VarChar(255)
