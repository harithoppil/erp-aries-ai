generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:Arieserp1!@aries-erp-ai.postgres.database.azure.com:5432/postgres?sslmode=require"
  schemas  = ["public", "app"]
}

model accounts {
  id                  String                @id @db.Uuid
  name                String                @unique @db.VarChar(200)
  account_number      String?               @db.VarChar(50)
  account_type        accounttype?
  root_type           String?               @db.VarChar(20)
  report_type         String?               @db.VarChar(50)
  parent_account      String?               @db.VarChar(200)
  is_group            Boolean
  company             String                @db.VarChar(200)
  account_currency    String                @db.VarChar(3)
  tax_rate            Float
  balance_must_be     String?               @db.VarChar(10)
  balance             Float
  lft                 Int
  rgt                 Int
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  gl_entries          gl_entries[]
  journal_entry_lines journal_entry_lines[]
  @@schema("public")
}

model ai_conversations {
  id          String        @id @db.Uuid
  persona_id  String        @db.Uuid
  user_id     String?       @db.VarChar(255)
  channel     String        @db.VarChar(50)
  title       String?       @db.VarChar(200)
  created_at  DateTime      @default(now()) @db.Timestamptz(6)
  updated_at  DateTime      @default(now()) @db.Timestamptz(6)
  ai_personas ai_personas   @relation(fields: [persona_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ai_messages ai_messages[]

  @@index([channel], map: "ix_ai_conversations_channel")
  @@index([persona_id], map: "ix_ai_conversations_persona_id")
  @@index([user_id], map: "ix_ai_conversations_user_id")
  @@schema("public")
}

model ai_messages {
  id               String           @id @db.Uuid
  conversation_id  String           @db.Uuid
  role             String           @db.VarChar(50)
  content          String?
  tool_calls       String?
  tool_call_id     String?          @db.VarChar(100)
  tool_name        String?          @db.VarChar(100)
  metadata_json    String?
  created_at       DateTime         @default(now()) @db.Timestamptz(6)
  ai_conversations ai_conversations @relation(fields: [conversation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([conversation_id], map: "ix_ai_messages_conversation_id")
  @@index([created_at], map: "ix_ai_messages_created_at")
  @@schema("public")
}

model ai_personas {
  id                    String               @id @db.Uuid
  username              String               @unique @db.VarChar(100)
  nickname              String               @db.VarChar(100)
  position              String               @db.VarChar(200)
  category              String               @db.VarChar(20)
  about                 String?
  greeting              String?
  model                 String               @db.VarChar(100)
  temperature           Float
  allowed_tools         String?
  allowed_collections   String?
  allowed_mcp_servers   String?
  enable_knowledge_base Boolean
  knowledge_base_prompt String?
  enabled               Boolean
  built_in              Boolean
  created_at            DateTime             @default(now()) @db.Timestamptz(6)
  updated_at            DateTime             @default(now()) @db.Timestamptz(6)
  ai_conversations      ai_conversations[]
  channel_connectors    channel_connectors[]
  @@schema("public")
}

model assets {
  id                      String                @id @db.Uuid
  asset_name              String                @db.VarChar(255)
  asset_code              String                @unique @db.VarChar(100)
  asset_category          String                @db.VarChar(100)
  status                  assetstatus
  location                String?               @db.VarChar(200)
  warehouse_id            String?               @db.Uuid
  purchase_date           DateTime?             @db.Timestamptz(6)
  purchase_cost           Float?
  current_value           Float?
  depreciation_rate       Float
  calibration_date        DateTime?             @db.Timestamptz(6)
  next_calibration_date   DateTime?             @db.Timestamptz(6)
  calibration_certificate String?               @db.VarChar(500)
  certification_body      String?               @db.VarChar(200)
  assigned_to_project     String?               @db.Uuid
  assigned_to_personnel   String?               @db.Uuid
  notes                   String?
  created_at              DateTime              @default(now()) @db.Timestamptz(6)
  updated_at              DateTime              @default(now()) @db.Timestamptz(6)
  personnel               personnel?            @relation(fields: [assigned_to_personnel], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects                projects?             @relation(fields: [assigned_to_project], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouses              warehouses?           @relation(fields: [warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  maintenance_records     maintenance_records[]

  @@index([assigned_to_personnel], map: "ix_assets_assigned_to_personnel")
  @@index([assigned_to_project], map: "ix_assets_assigned_to_project")
  @@index([warehouse_id], map: "ix_assets_warehouse_id")
  @@schema("public")
}

model audit_log {
  id         String    @id @db.Uuid
  enquiry_id String    @db.Uuid
  action     String    @db.VarChar(100)
  actor      String    @db.VarChar(255)
  details    String?
  node       String?   @db.VarChar(50)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  enquiries  enquiries @relation(fields: [enquiry_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  @@schema("public")
}

model bins {
  id             String     @id @db.Uuid
  item_id        String     @db.Uuid
  warehouse_id   String     @db.Uuid
  quantity       Float
  valuation_rate Float
  stock_value    Float
  updated_at     DateTime   @default(now()) @db.Timestamptz(6)
  items          items      @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouses     warehouses @relation(fields: [warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([item_id], map: "ix_bins_item_id")
  @@index([warehouse_id], map: "ix_bins_warehouse_id")
  @@schema("public")
}

model certifications {
  id           String     @id @db.Uuid
  personnel_id String     @db.Uuid
  cert_type    String     @db.VarChar(100)
  cert_number  String?    @db.VarChar(100)
  issuing_body String?    @db.VarChar(200)
  issue_date   DateTime?  @db.Timestamptz(6)
  expiry_date  DateTime?  @db.Timestamptz(6)
  status       certstatus
  personnel    personnel  @relation(fields: [personnel_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([personnel_id], map: "ix_certifications_personnel_id")
  @@index([status], map: "ix_certifications_status")
  @@schema("public")
}

model channel_connectors {
  id                 String       @id @db.Uuid
  channel_type       String       @db.VarChar(50)
  name               String       @db.VarChar(200)
  enabled            Boolean
  config             String?
  webhook_url        String?      @db.VarChar(500)
  default_persona_id String?      @db.Uuid
  created_at         DateTime     @default(now()) @db.Timestamptz(6)
  ai_personas        ai_personas? @relation(fields: [default_persona_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  @@schema("public")
}

model customers {
  id             String         @id @db.Uuid
  customer_name  String         @db.VarChar(255)
  customer_code  String         @unique @db.VarChar(50)
  contact_person String?        @db.VarChar(255)
  email          String?        @db.VarChar(255)
  phone          String?        @db.VarChar(50)
  address        String?
  industry       String?        @db.VarChar(100)
  tax_id         String?        @db.VarChar(50)
  credit_limit   Float?
  status         String         @db.VarChar(20)
  created_at     DateTime       @default(now()) @db.Timestamptz(6)
  quotations     quotations[]
  sales_orders   sales_orders[]
  @@schema("public")
}

model documents {
  id                String    @id @db.Uuid
  enquiry_id        String    @db.Uuid
  filename          String    @db.VarChar(500)
  content_type      String    @db.VarChar(100)
  storage_path      String    @db.VarChar(1000)
  wiki_source_page  String?   @db.VarChar(500)
  markdown_content  String?
  processing_status String    @db.VarChar(50)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  enquiries         enquiries @relation(fields: [enquiry_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  @@schema("public")
}

model enquiries {
  id                  String                @id @db.Uuid
  enquiry_number      String?               @unique(map: "ix_enquiries_enquiry_number") @db.VarChar(50)
  client_name         String                @db.VarChar(255)
  client_email        String?               @db.VarChar(255)
  channel             String                @db.VarChar(50)
  industry            String?               @db.VarChar(100)
  subdivision         String?               @db.VarChar(100)
  description         String
  status              enquirystatus
  estimated_value     Float?
  estimated_cost      Float?
  estimated_margin    Float?
  scope_category      String?               @db.VarChar(100)
  complexity          String?               @db.VarChar(50)
  resource_profile    String?
  approved_by         String?               @db.VarChar(255)
  approved_at         DateTime?             @db.Timestamptz(6)
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @default(now()) @db.Timestamptz(6)
  audit_log           audit_log[]
  documents           documents[]
  projects            projects[]
  quotations          quotations[]
  sales_invoices      sales_invoices[]
  workflow_executions workflow_executions[]

  @@index([status], map: "ix_enquiries_status")
  @@schema("public")
}

model invoice_items {
  id             String         @id @db.Uuid
  invoice_id     String         @db.Uuid
  item_code      String?        @db.VarChar(100)
  description    String
  quantity       Int
  rate           Float
  amount         Float
  sales_invoices sales_invoices @relation(fields: [invoice_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  @@schema("public")
}

model items {
  id               String               @id @db.Uuid
  item_code        String               @unique @db.VarChar(100)
  item_name        String               @db.VarChar(255)
  item_group       itemgroup
  description      String?
  unit             String               @db.VarChar(20)
  has_batch        Boolean
  has_serial       Boolean
  valuation_method stockvaluationmethod
  standard_rate    Float?
  min_order_qty    Float?
  safety_stock     Float?
  created_at       DateTime             @default(now()) @db.Timestamptz(6)
  bins             bins[]
  stock_entry_items stock_entry_items[]
  @@schema("public")
}

model journal_entries {
  id                  String                @id @db.Uuid
  entry_number        String                @unique @db.VarChar(50)
  posting_date        DateTime              @default(now()) @db.Timestamptz(6)
  reference           String?               @db.VarChar(200)
  account             String?               @db.VarChar(255)
  party_type          String?               @db.VarChar(50)
  party_name          String?               @db.VarChar(255)
  entry_type          journalentrytype?
  amount              Float?
  currency            String                @db.VarChar(3)
  notes               String?
  total_debit         Float
  total_credit        Float
  status              String                @db.VarChar(20)
  subsidiary_id       String?               @db.Uuid
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  subsidiaries        subsidiaries?         @relation(fields: [subsidiary_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  journal_entry_lines journal_entry_lines[]
  @@schema("public")
}

model maintenance_records {
  id               String    @id @db.Uuid
  asset_id         String    @db.Uuid
  maintenance_type String    @db.VarChar(50)
  description      String
  performed_by     String    @db.VarChar(255)
  performed_date   DateTime  @db.Timestamptz(6)
  next_due_date    DateTime? @db.Timestamptz(6)
  cost             Float
  assets           assets    @relation(fields: [asset_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  @@schema("public")
}

model material_requests {
  id             String    @id @db.Uuid
  request_number String    @unique @db.VarChar(50)
  project_id     String?   @db.Uuid
  requested_by   String    @db.VarChar(255)
  purpose               String?
  material_request_type String?   @db.VarChar(50)
  status                String    @db.VarChar(50)
  created_at            DateTime  @default(now()) @db.Timestamptz(6)
  projects       projects? @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  @@schema("public")
}

model node_executions {
  id                  String              @id @db.Uuid
  execution_id        String              @db.Uuid
  node_key            String              @db.VarChar(100)
  status              String              @db.VarChar(20)
  input_data          String?
  output_data         String?
  error_message       String?
  duration_ms         Int?
  started_at          DateTime?           @db.Timestamptz(6)
  completed_at        DateTime?           @db.Timestamptz(6)
  workflow_executions workflow_executions @relation(fields: [execution_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([execution_id], map: "ix_node_executions_execution_id")
  @@schema("public")
}

model notebooks {
  id            String   @id @db.Uuid
  title         String   @db.VarChar(255)
  content       String?
  metadata_json String?
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @db.Timestamptz(6)
  @@schema("public")
}

model payment_entries {
  id               String          @id @db.Uuid
  invoice_id       String?         @db.Uuid
  payment_type     String          @db.VarChar(50)
  party_type       String          @db.VarChar(50)
  party_name       String          @db.VarChar(255)
  amount           Float
  currency         String          @db.VarChar(3)
  reference_number String?         @db.VarChar(100)
  reference_date   DateTime?       @db.Timestamptz(6)
  posting_date     DateTime        @default(now()) @db.Timestamptz(6)
  sales_invoices   sales_invoices? @relation(fields: [invoice_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  @@schema("public")
}

model personnel {
  id                  String                @id @db.Uuid
  employee_id         String                @unique @db.VarChar(50)
  first_name          String                @db.VarChar(100)
  last_name           String                @db.VarChar(100)
  email               String?               @db.VarChar(255)
  phone               String?               @db.VarChar(50)
  status              personnelstatus
  designation         String?               @db.VarChar(100)
  department          String?               @db.VarChar(100)
  day_rate            Float?
  currency            String                @db.VarChar(3)
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  assets              assets[]
  certifications      certifications[]
  project_assignments project_assignments[]
  timesheets          timesheets[]
  @@schema("public")
}

model po_items {
  id              String          @id @db.Uuid
  po_id           String          @db.Uuid
  item_code       String?         @db.VarChar(100)
  description     String
  quantity        Int
  rate            Float
  amount          Float
  received_qty    Int             @default(0)
  schedule_date   DateTime?       @db.Timestamptz(6)
  purchase_orders purchase_orders @relation(fields: [po_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  @@schema("public")
}

model project_assignments {
  id                 String    @id @db.Uuid
  project_id         String    @db.Uuid
  personnel_id       String    @db.Uuid
  role               String    @db.VarChar(100)
  compliance_checked Boolean
  compliance_passed  Boolean
  compliance_issues  String?
  personnel          personnel @relation(fields: [personnel_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects           projects  @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([personnel_id], map: "ix_project_assignments_personnel_id")
  @@index([project_id], map: "ix_project_assignments_project_id")
  @@schema("public")
}

model projects {
  id                  String                @id @db.Uuid
  project_name        String                @db.VarChar(255)
  project_code        String                @unique @db.VarChar(50)
  project_type        String                @db.VarChar(100)
  status              projectstatus
  enquiry_id          String?               @db.Uuid
  customer_name       String                @db.VarChar(255)
  expected_start      DateTime?             @db.Timestamptz(6)
  expected_end        DateTime?             @db.Timestamptz(6)
  actual_start        DateTime?             @db.Timestamptz(6)
  actual_end          DateTime?             @db.Timestamptz(6)
  project_location    String?               @db.VarChar(200)
  vessel_name         String?               @db.VarChar(200)
  estimated_cost      Float?
  actual_cost         Float
  day_rate            Float?
  currency            String                @db.VarChar(3)
  notes               String?
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @default(now()) @db.Timestamptz(6)
  assets              assets[]
  gl_entries          gl_entries[]
  journal_entry_lines journal_entry_lines[]
  material_requests   material_requests[]
  project_assignments project_assignments[]
  enquiries           enquiries?            @relation(fields: [enquiry_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purchase_orders     purchase_orders[]
  tasks               tasks[]
  timesheets          timesheets[]
  @@schema("public")
}

model purchase_orders {
  id                String     @id @db.Uuid
  po_number         String     @unique @db.VarChar(50)
  supplier_id       String     @db.Uuid
  project_id        String?    @db.Uuid
  status            postatus
  order_date        DateTime   @default(now()) @db.Timestamptz(6)
  expected_delivery DateTime?  @db.Timestamptz(6)
  subtotal          Float
  tax_amount        Float
  total             Float
  currency          String     @db.VarChar(3)
  notes             String?
  created_at        DateTime   @default(now()) @db.Timestamptz(6)
  po_items          po_items[]
  projects          projects?  @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  suppliers         suppliers  @relation(fields: [supplier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  @@schema("public")
}

model quality_inspections {
  id                String   @id @db.Uuid
  inspection_type   String   @db.VarChar(100)
  reference         String?  @db.VarChar(200)
  status            String   @db.VarChar(50)
  findings          String?
  corrective_action String?
  inspected_by      String   @db.VarChar(255)
  inspection_date   DateTime @default(now()) @db.Timestamptz(6)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  @@schema("public")
}

model quotation_items {
  id           String     @id @db.Uuid
  quotation_id String     @db.Uuid
  item_code    String?    @db.VarChar(100)
  description  String
  quantity     Int
  rate         Float
  amount       Float
  quotations   quotations @relation(fields: [quotation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  @@schema("public")
}

model quotations {
  id               String            @id @db.Uuid
  quotation_number String            @unique @db.VarChar(50)
  enquiry_id       String?           @db.Uuid
  customer_id      String?           @db.Uuid
  customer_name    String            @db.VarChar(255)
  project_type     String?           @db.VarChar(100)
  valid_until      DateTime?         @db.Timestamptz(6)
  status           quotationstatus
  subtotal         Float
  tax_rate         Float
  tax_amount       Float
  total            Float
  currency         String            @db.VarChar(3)
  notes            String?
  created_at       DateTime          @default(now()) @db.Timestamptz(6)
  quotation_items  quotation_items[]
  customers        customers?        @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  enquiries        enquiries?        @relation(fields: [enquiry_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales_orders     sales_orders[]
  @@schema("public")
}

model sales_invoices {
  id                 String              @id @db.Uuid
  invoice_number     String              @unique @db.VarChar(50)
  enquiry_id         String?             @db.Uuid
  customer_name      String              @db.VarChar(255)
  customer_email     String?             @db.VarChar(255)
  posting_date       DateTime            @default(now()) @db.Timestamptz(6)
  due_date           DateTime?           @db.Timestamptz(6)
  status             salesinvoicestatus
  subtotal           Float
  tax_rate           Float
  tax_amount         Float
  total              Float
  currency           String              @db.VarChar(3)
  paid_amount        Float
  outstanding_amount Float
  document_id        String?             @db.Uuid
  created_at         DateTime            @default(now()) @db.Timestamptz(6)
  invoice_items      invoice_items[]
  payment_entries    payment_entries[]
  uploaded_documents uploaded_documents? @relation(fields: [document_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  enquiries          enquiries?          @relation(fields: [enquiry_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  @@schema("public")
}

model sales_order_items {
  id             String       @id @db.Uuid
  sales_order_id String       @db.Uuid
  item_code      String?      @db.VarChar(100)
  description    String
  quantity       Int
  rate           Float
  amount         Float
  delivered_qty  Int
  sales_orders   sales_orders @relation(fields: [sales_order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  @@schema("public")
}

model sales_orders {
  id                String              @id @db.Uuid
  order_number      String              @unique @db.VarChar(50)
  quotation_id      String?             @db.Uuid
  customer_id       String?             @db.Uuid
  customer_name     String              @db.VarChar(255)
  project_type      String?             @db.VarChar(100)
  delivery_date     DateTime?           @db.Timestamptz(6)
  status            salesorderstatus
  subtotal          Float
  tax_rate          Float
  tax_amount        Float
  total             Float
  currency          String              @db.VarChar(3)
  notes             String?
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  sales_order_items sales_order_items[]
  customers         customers?          @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  quotations        quotations?         @relation(fields: [quotation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  @@schema("public")
}

model stock_entries {
  id                String            @id @db.Uuid
  entry_number      String?           @unique @db.VarChar(50)
  entry_type        String            @db.VarChar(50)
  posting_date      DateTime          @default(now()) @db.Timestamptz(6)
  from_warehouse_id String?           @db.Uuid
  to_warehouse_id   String?           @db.Uuid
  project_id        String?           @db.Uuid
  status            String            @db.VarChar(20)
  total_amount      Float?
  currency          String            @db.VarChar(3)
  notes             String?
  created_at        DateTime          @default(now()) @db.Timestamptz(6)
  stock_entry_items stock_entry_items[]
  from_warehouse    warehouses?       @relation("stock_entries_from_warehouse", fields: [from_warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  to_warehouse      warehouses?       @relation("stock_entries_to_warehouse", fields: [to_warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model stock_entry_items {
  id             String        @id @db.Uuid
  stock_entry_id String        @db.Uuid
  item_id        String        @db.Uuid
  item_code      String?       @db.VarChar(100)
  qty            Float
  rate           Float?
  amount         Float?
  serial_no      String?       @db.VarChar(100)
  batch_no       String?       @db.VarChar(100)
  stock_entries  stock_entries @relation(fields: [stock_entry_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items          items         @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([stock_entry_id], map: "ix_stock_entry_items_stock_entry_id")
  @@index([item_id], map: "ix_stock_entry_items_item_id")
  @@schema("public")
}

model suppliers {
