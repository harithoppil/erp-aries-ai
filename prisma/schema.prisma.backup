  supplier_name      String              @db.VarChar(255)
  supplier_code      String              @unique @db.VarChar(50)
  contact_person     String?             @db.VarChar(255)
  email              String?             @db.VarChar(255)
  phone              String?             @db.VarChar(50)
  address            String?
  category           String?             @db.VarChar(100)
  rating             Float?
  status             String?             @db.VarChar(20)
  disabled           Boolean             @default(false)
  prevent_pos        Boolean             @default(false)
  warn_pos           Boolean             @default(false)
  document_id        String?             @db.Uuid
  created_at         DateTime            @default(now()) @db.Timestamptz(6)
  purchase_orders    purchase_orders[]
  uploaded_documents uploaded_documents? @relation(fields: [document_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  @@schema("public")
}

model tasks {
