  accounts         accounts?       @relation(fields: [account_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  journal_entries  journal_entries @relation(fields: [journal_entry_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects         projects?       @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([journal_entry_id], map: "ix_journal_entry_lines_journal_entry_id")
  @@schema("public")
}

model subsidiaries {
  id                         String            @id @db.Uuid
  name                       String            @db.VarChar(200)
  abbr                       String?           @db.VarChar(20)
  default_currency           String            @db.VarChar(3)
  country                    String?           @db.VarChar(100)
  tax_id                     String?           @db.VarChar(50)
  default_receivable_account String?           @db.VarChar(200)
  default_payable_account    String?           @db.VarChar(200)
  default_income_account     String?           @db.VarChar(200)
  default_expense_account    String?           @db.VarChar(200)
  default_bank_account       String?           @db.VarChar(200)
  default_cash_account       String?           @db.VarChar(200)
  cost_center                String?           @db.VarChar(200)
  created_at                 DateTime          @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime          @default(now()) @db.Timestamptz(6)
  cost_centers               cost_centers[]
  fiscal_years               fiscal_years[]
  gl_entries                 gl_entries[]
  journal_entries            journal_entries[]
  @@schema("public")
}

enum accounttype {
  ASSET
  LIABILITY
  INCOME
  EXPENSE
  EQUITY
  RECEIVABLE
  PAYABLE
  @@schema("public")
}

enum assetstatus {
  AVAILABLE
  IN_USE
  UNDER_MAINTENANCE
  CALIBRATION_DUE
  DECOMMISSIONED
  @@schema("public")
}

enum certstatus {
  VALID
  EXPIRING_SOON
  EXPIRED
  SUSPENDED
  @@schema("public")
}

enum doctype {
  INVOICE
  RECEIPT
  CONTRACT
  CERTIFICATE
  REPORT
  OTHER
  @@schema("public")
}

enum enquirystatus {
  DRAFT
  INGESTED
  CLASSIFIED
  RULES_APPLIED
  LLM_DRAFTED
  POLICY_REVIEW
  HUMAN_REVIEW
  APPROVED
  EXECUTING
  COMPLETED
  REJECTED
  @@schema("public")
}

enum itemgroup {
  CONSUMABLE
  EQUIPMENT
  SERVICE
  RAW_MATERIAL
  SPARE_PART
  @@schema("public")
}

enum journalentrytype {
  DEBIT
  CREDIT
  @@schema("public")
}

enum personnelstatus {
  ACTIVE
  ON_PROJECT
  ON_LEAVE
  INACTIVE
  @@schema("public")
}

enum postatus {
  DRAFT
  SUBMITTED
  APPROVED
  RECEIVED
  CANCELLED
  @@schema("public")
}

enum processingstatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  @@schema("public")
}

enum projectstatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  @@schema("public")
}

enum quotationstatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  @@schema("public")
}

enum salesinvoicestatus {
  DRAFT
  SUBMITTED
  PAID
  CANCELLED
  OVERDUE
  @@schema("public")
}

enum salesorderstatus {
  DRAFT
  TO_DELIVER
  TO_BILL
  COMPLETED
  CANCELLED
  @@schema("public")
}

enum stockvaluationmethod {
  FIFO
