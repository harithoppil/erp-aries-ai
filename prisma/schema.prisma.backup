  workflows        workflows         @relation(fields: [workflow_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([enquiry_id], map: "ix_workflow_executions_enquiry_id")
  @@index([workflow_id], map: "ix_workflow_executions_workflow_id")
