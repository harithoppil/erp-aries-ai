  is_cancelled               Boolean
  remarks                    String?
  created_at                 DateTime      @default(now()) @db.Timestamptz(6)
  accounts                   accounts?     @relation(fields: [account_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects                   projects?     @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subsidiaries               subsidiaries? @relation(fields: [subsidiary_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([account_id], map: "ix_gl_entries_account_id")
